{
  "name": "padtools_ts",
  "version": "0.2.0",
  "bin": {
    "padtools_ts": "dist/cli/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "prepublishOnly": "npm run build && npm run build:web",
    "format": "biome format --write .",
    "start": "ts-node src/cli/cli.ts",
    "start:api": "ts-node src/api/server.ts",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:headed": "playwright test --headed",
    "test:cov": "jest --coverage",
    "update-cli-golden-files": "node tests/cli/E2E/updateGoldenFile.js",
    "update-spd-golden-files": "node tests/spd/E2E/updateGoldenFile.js",
    "update-web-golden-files": "node tests/web/updateGoldenFile.js",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:apply": "biome check --write --unsafe .",
    "start:web": "parcel web/index.html --dist-dir temp/",
    "build:web": "rimraf dist/web && parcel build web/index.html --dist-dir dist/web",
    "build:web:gh-pages": "rimraf gh-pages/ && parcel build web/index.html --dist-dir gh-pages/ --public-url /padtools_ts/ && echo > gh-pages/.nojekyll",
    "convert:web:commands": "tsx web/utility/convert_commands.ts",
    "convert:web:render_options": "tsx web/utility/convert_render_options.ts"
  },
  "keywords": [
    "pad",
    "flowchart",
    "diagram",
    "generator",
    "cli",
    "svg",
    "typescript",
    "PAD"
  ],
  "author": "steelpipe",
  "license": "MIT",
  "description": "Simple tool to write PAD.",
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "commander": "^14.0.3",
    "eastasianwidth": "^0.3.0",
    "glob": "^13.0.6",
    "hono": "^4.12.15",
    "svgo": "^4.0.1",
    "xml-formatter": "^3.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@parcel/packager-ts": "^2.16.4",
    "@parcel/transformer-typescript-types": "^2.16.1",
    "@playwright/test": "^1.56.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/svgo": "^2.6.4",
    "@types/xml-formatter": "^2.1.1",
    "baseline-browser-mapping": "^2.10.24",
    "jest": "^30.3.0",
    "parcel": "^2.16.4",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "test-exclude": "7.0.1"
  }
}
